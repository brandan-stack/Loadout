{
  "name": "loadout",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/next-with-port.js dev 3004",
    "predev:test": "npm run prisma:generate:pg",
    "dev:test": "node scripts/next-with-port.js dev 3104",
    "build": "prisma generate --schema=./prisma/schema.postgresql.prisma && next build",
    "start": "node scripts/next-with-port.js start 3004",
    "prestart:test": "npm run prisma:generate:pg",
    "start:test": "node scripts/next-with-port.js start 3104",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:qa": "LOADOUT_QA_PORT=${LOADOUT_QA_PORT:-3104} playwright test dashboard-qa.spec.js",
    "test:site": "node scripts/run-full-site-qa.js",
    "prisma:generate": "prisma generate",
    "prisma:generate:pg": "prisma generate --schema=./prisma/schema.postgresql.prisma",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.postgresql.prisma",
    "prisma:reset": "prisma migrate reset --force",
    "db:push": "prisma db push",
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@supabase/supabase-js": "^2.110.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.0.0",
    "html2canvas": "^1.4.1",
    "jose": "^6.2.2",
    "jsbarcode": "^3.12.3",
    "jspdf": "^4.2.1",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "next": "^15.5.14",
    "nodemailer": "^8.0.4",
    "qrcode": "^1.5.4",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^29.5.8",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-config-next": "^15.5.14",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8.4.32",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.3.7",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
