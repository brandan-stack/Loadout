// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id           String            @id @default(cuid())
  name         String
  contactEmail String
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  users             AppUser[]
  items             Item[]
  suppliers         Supplier[]
  jobs              Job[]
  tools             Tool[]
  reportViews       ReportView[]
  shareLogs         ShareLog[]
  itemVariants      ItemVariant[]
  locations         Location[]
  locationTransfers LocationTransfer[]
  scheduledReports  ScheduledReport[]
  settings          Settings?
}

model Item {
  id                    String   @id @default(cuid())
  organizationId        String
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                  String
  manufacturer          String?
  partNumber            String?
  modelNumber           String?
  serialNumber          String?
  barcode               String?
  description           String?
  quantityOnHand        Int      @default(0)
  quantityUsedTotal     Int      @default(0)
  
  // Low stock thresholds
  lowStockAmberThreshold Int      @default(5)
  lowStockRedThreshold   Int      @default(2)
  
  // Supplier
  preferredSupplierId   String?
  preferredSupplier     Supplier?  @relation(fields: [preferredSupplierId], references: [id])
  lastUnitCost          Float?
  
  // Variants (Wave B feature)
  unitOfMeasure         String   @default("each")
  
  // Lot/expiry (Wave B feature)
  enableLotTracking     Boolean  @default(false)
  enableExpiryTracking  Boolean  @default(false)
  
  // Photos
  photoUrl              String?
  photos                ItemPhoto[]
  
  // Transactions
  transactions          InventoryTransaction[]
  
  // Variants (Wave B feature)
  variants              ItemVariant[]
  
  // Multi-location stock
  locationStock         LocationStock[]

  // Job parts
  jobParts              JobPart[]

  // Dates
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  
  @@unique([organizationId, barcode])
  @@index([organizationId])
  @@index([organizationId, barcode])
  @@index([organizationId, lowStockRedThreshold])
}

model ItemPhoto {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  fileName  String
  filePath  String
  isPrimary Boolean  @default(false)
  notes     String?
  size      Int      @default(0)
  createdAt DateTime @default(now())
  
  @@index([itemId])
}

model InventoryTransaction {
  id        String   @id @default(cuid())
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  
  type      String   // "add" | "use" | "adjust"
  quantity  Int
  
  // Optional lot/expiry tracking
  lotNumber String?
  expiryDate DateTime?
  
  notes     String?
  createdAt DateTime @default(now())
  
  @@index([itemId])
  @@index([createdAt])
  @@index([type])
}

model Supplier {
  id        String   @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name      String
  contact   String?
  website   String?
  leadTimeD Int      @default(7)
  notes     String?
  archived  Boolean  @default(false)
  items     Item[]   @relation()
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model AppUser {
  id               String    @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  email            String    @unique
  role             String    @default("TECH") // "SUPER_ADMIN" | "OFFICE" | "TECH"
  passwordHash     String
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  jobs      Job[]          @relation("TechJobs")
  tools     Tool[]         @relation("PersonalTools")
  checkouts ToolCheckout[]

  @@index([organizationId])
}

model Job {
  id           String    @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  jobNumber    String
  customer     String
  technicianId String
  technician   AppUser   @relation("TechJobs", fields: [technicianId], references: [id])
  date         DateTime  @default(now())
  status       String    @default("OPEN") // "OPEN" | "COMPLETED" | "INVOICED"
  notes        String?
  parts        JobPart[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([organizationId, jobNumber])
  @@index([organizationId])
  @@index([technicianId])
  @@index([status])
  @@index([organizationId, jobNumber])
}

model JobPart {
  id        String   @id @default(cuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  itemId    String
  item      Item     @relation(fields: [itemId], references: [id])
  quantity  Int
  unitCost  Float    @default(0)
  notes     String?
  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([itemId])
}

model Tool {
  id           String         @id @default(cuid())
  organizationId String
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name         String
  manufacturer String?
  partNumber   String?
  modelNumber  String?
  supplier     String?
  cost         Float          @default(0)
  notes        String?
  photoUrl     String?
  type         String         @default("SHOP") // "SHOP" | "PERSONAL"
  ownerId      String?
  owner        AppUser?       @relation("PersonalTools", fields: [ownerId], references: [id])
  checkouts    ToolCheckout[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([name])
  @@index([supplier])
  @@index([ownerId])
  @@index([organizationId])
}

model ToolCheckout {
  id           String    @id @default(cuid())
  toolId       String
  tool         Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)
  userId       String
  user         AppUser   @relation(fields: [userId], references: [id])
  checkedOutAt DateTime  @default(now())
  returnedAt   DateTime?
  notes        String?

  @@index([toolId])
  @@index([userId])
}

model ReportView {
  id        String   @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name      String
  type      String   // "low_stock" | "usage_period" | "dead_stock" | "fast_movers"
  filters   String   @default("{}") // JSON stored as string
  sortBy    String   @default("name")
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
}

model ShareLog {
  id           String   @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  type         String   // "pdf" | "email"
  reportType   String?
  emailClient  String?  // "apple_mail" | "gmail" | "outlook" | "default"
  filters      String   @default("{}") // JSON
  createdAt    DateTime @default(now())

  @@index([organizationId])
}

model ItemVariant {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  itemId         String
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  name           String   // e.g. "Red / Large"
  sku            String?
  quantityOnHand Int      @default(0)
  attributes     String   @default("{}") // JSON: { size, color, etc. }
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([itemId])
}

model Location {
  id          String         @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name        String
  description String?
  archived    Boolean        @default(false)
  stock       LocationStock[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model LocationStock {
  id             String   @id @default(cuid())
  locationId     String
  location       Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  itemId         String
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  quantityOnHand Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@unique([locationId, itemId])
  @@index([locationId])
  @@index([itemId])
}

model LocationTransfer {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromLocationId String
  toLocationId   String
  itemId         String
  quantity       Int
  notes          String?
  createdAt      DateTime @default(now())

  @@index([itemId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([organizationId])
}

model ScheduledReport {
  id         String   @id @default(cuid())
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name       String
  reportType String   // "low_stock" | "usage_period" | "dead_stock" | "fast_movers"
  frequency  String   // "daily" | "weekly" | "monthly"
  filters    String   @default("{}") // JSON
  lastRun    DateTime?
  nextRun    DateTime
  archived   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([organizationId])
}

model Settings {
  id                    String    @id @default(cuid())
  organizationId        String    @unique
  organization          Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  premiumEnabled        Boolean   @default(false)
  simpleMode            Boolean   @default(true)
  
  // Feature toggles
  enableMultiLocation   Boolean   @default(false)
  enableVariants        Boolean   @default(false)
  enableImportWizard    Boolean   @default(false)
  enableLotExpiry       Boolean   @default(false)
  enableBackupZip       Boolean   @default(false)
  enableReportScheduler Boolean   @default(false)
  enableAITagging       Boolean   @default(false)
  
  // Email
  preferredEmailClient  String    @default("default") // "apple_mail" | "gmail" | "outlook" | "default"
  composeSubjectTemplate String   @default("Inventory Report - {date}")
  
  // Thresholds
  defaultLowStockAmber  Int       @default(5)
  defaultLowStockRed    Int       @default(2)
  
  updatedAt             DateTime  @updatedAt
}
