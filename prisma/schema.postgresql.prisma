generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Organization {
  id                    String                 @id @default(cuid())
  name                  String
  contactEmail          String
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  users                 AppUser[]
  inventoryTransactions InventoryTransaction[]
  items                 Item[]
  itemVariants          ItemVariant[]
  jobs                  Job[]
  locations             Location[]
  locationTransfers     LocationTransfer[]
  reportViews           ReportView[]
  scheduledReports      ScheduledReport[]
  settings              Settings?
  shareLogs             ShareLog[]
  suppliers             Supplier[]
  tools                 Tool[]
  toolTransactions      ToolTransaction[]
}

model Item {
  id                     String                 @id @default(cuid())
  name                   String
  manufacturer           String?
  partNumber             String?
  modelNumber            String?
  serialNumber           String?
  barcode                String?
  description            String?
  quantityOnHand         Int                    @default(0)
  quantityUsedTotal      Int                    @default(0)
  lowStockAmberThreshold Int                    @default(5)
  lowStockRedThreshold   Int                    @default(2)
  preferredSupplierId    String?
  lastUnitCost           Float?
  unitOfMeasure          String                 @default("each")
  enableLotTracking      Boolean                @default(false)
  enableExpiryTracking   Boolean                @default(false)
  photoUrl               String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  organizationId         String
  category               String?
  defaultLocationId      String?
  lastMovementAt         DateTime?
  lastMovementType       String?
  marginPercent          Float                  @default(0)
  transactions           InventoryTransaction[]
  defaultLocation        Location?              @relation("DefaultItemLocation", fields: [defaultLocationId], references: [id])
  organization           Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  preferredSupplier      Supplier?              @relation(fields: [preferredSupplierId], references: [id])
  photos                 ItemPhoto[]
  variants               ItemVariant[]
  jobParts               JobPart[]
  locationStock          LocationStock[]

  @@unique([organizationId, barcode])
  @@index([organizationId])
  @@index([organizationId, barcode])
  @@index([organizationId, lowStockRedThreshold])
  @@index([defaultLocationId])
  @@index([organizationId, category])
  @@index([organizationId, lastMovementAt])
  @@index([barcode])
  @@index([lowStockRedThreshold])
}

model ItemPhoto {
  id        String   @id @default(cuid())
  itemId    String
  fileName  String
  filePath  String
  isPrimary Boolean  @default(false)
  notes     String?
  size      Int      @default(0)
  createdAt DateTime @default(now())
  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
}

model InventoryTransaction {
  id                     String       @id @default(cuid())
  itemId                 String
  type                   String
  quantity               Int
  lotNumber              String?
  expiryDate             DateTime?
  notes                  String?
  createdAt              DateTime     @default(now())
  organizationId         String
  actorUserId            String?
  fromLocationId         String?
  toLocationId           String?
  jobId                  String?
  quantityDelta          Int?
  balanceAfter           Int?
  jobNumberSnapshot      String?
  jobDescriptionSnapshot String?
  costSnapshot           Float?
  clientRequestId        String?      @unique
  submittedOfflineAt     DateTime?
  syncedAt               DateTime?
  syncStatus             String       @default("synced")
  actorUser              AppUser?     @relation("InventoryTransactionsActor", fields: [actorUserId], references: [id])
  fromLocation           Location?    @relation("InventoryTransactionsFromLocation", fields: [fromLocationId], references: [id])
  item                   Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  job                    Job?         @relation(fields: [jobId], references: [id])
  organization           Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  toLocation             Location?    @relation("InventoryTransactionsToLocation", fields: [toLocationId], references: [id])
  jobParts               JobPart[]

  @@index([itemId])
  @@index([createdAt])
  @@index([type])
  @@index([organizationId])
  @@index([actorUserId])
  @@index([jobId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([organizationId, createdAt])
}

model Supplier {
  id             String       @id @default(cuid())
  name           String
  contact        String?
  website        String?
  leadTimeD      Int          @default(7)
  notes          String?
  archived       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  emailContacts  Json         @default("[]")
  isPreferred    Boolean      @default(false)
  isFastest      Boolean      @default(false)
  items          Item[]
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([organizationId, isPreferred])
  @@index([organizationId, isFastest])
}

model AppUser {
  id                        String                 @id @default(cuid())
  name                      String
  role                      String                 @default("TECH")
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt
  email                     String                 @unique
  supabaseAuthUserId        String?                @unique
  passwordHash              String
  resetToken                String?
  resetTokenExpiry          DateTime?
  organizationId            String
  rolePreset                String                 @default("STANDARD")
  financialVisibilityMode   String                 @default("total_only")
  canViewDashboard          Boolean                @default(false)
  canViewJobs               Boolean                @default(false)
  canViewInventory          Boolean                @default(false)
  canViewTools              Boolean                @default(false)
  canViewReports            Boolean                @default(false)
  canViewSuppliers          Boolean                @default(false)
  canViewReorder            Boolean                @default(false)
  canViewSettings           Boolean                @default(false)
  canAddInventory           Boolean                @default(false)
  canEditInventory          Boolean                @default(false)
  canMoveInventory          Boolean                @default(false)
  canRemoveInventory        Boolean                @default(false)
  canUseInventoryOnJob      Boolean                @default(false)
  canReturnInventoryFromJob Boolean                @default(false)
  canManageLocations        Boolean                @default(false)
  canManageCategories       Boolean                @default(false)
  canCreateJobs             Boolean                @default(false)
  canEditJobs               Boolean                @default(false)
  canCloseJobs              Boolean                @default(false)
  canInvoiceJobs            Boolean                @default(false)
  canViewJobSummaries       Boolean                @default(false)
  canViewOwnTools           Boolean                @default(false)
  canAddOwnTools            Boolean                @default(false)
  canEditOwnTools           Boolean                @default(false)
  canViewCompanyTools       Boolean                @default(false)
  canRequestCompanyTools    Boolean                @default(false)
  canCheckoutCompanyTools   Boolean                @default(false)
  canReturnCompanyTools     Boolean                @default(false)
  canAcceptToolReturns      Boolean                @default(false)
  canManageCompanyTools     Boolean                @default(false)
  canManageUsers            Boolean                @default(false)
  canManageSettings         Boolean                @default(false)
  canExportData             Boolean                @default(false)
  canBackupRestore          Boolean                @default(false)
  canClearCache             Boolean                @default(false)
  canEnableModules          Boolean                @default(false)
  canViewBasePrice          Boolean                @default(false)
  canViewMarginPrice        Boolean                @default(false)
  canViewTotalPrice         Boolean                @default(false)
  organization              Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryTransactions     InventoryTransaction[] @relation("InventoryTransactionsActor")
  jobs                      Job[]                  @relation("TechJobs")
  jobMaterialUsages         JobPart[]              @relation("JobPartPerformedBy")
  assignedCompanyTools      Tool[]                 @relation("AssignedCompanyTools")
  tools                     Tool[]                 @relation("PersonalTools")
  checkouts                 ToolCheckout[]
  acceptedToolTransactions  ToolTransaction[]      @relation("AcceptedToolTransactions")
  approvedToolTransactions  ToolTransaction[]      @relation("ApprovedToolTransactions")
  heldToolTransactions      ToolTransaction[]      @relation("HeldToolTransactions")
  requestedToolTransactions ToolTransaction[]      @relation("RequestedToolTransactions")

  @@index([organizationId])
  @@index([organizationId, rolePreset])
}

model Job {
  id               String                 @id @default(cuid())
  jobNumber        String
  customer         String
  technicianId     String
  date             DateTime               @default(now())
  status           String                 @default("OPEN")
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  organizationId   String
  description      String?
  latestActivityAt DateTime               @default(now())
  billingTotal     Float?
  transactions     InventoryTransaction[]
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  technician       AppUser                @relation("TechJobs", fields: [technicianId], references: [id])
  parts            JobPart[]

  @@unique([organizationId, jobNumber])
  @@index([organizationId])
  @@index([technicianId])
  @@index([status])
  @@index([organizationId, jobNumber])
  @@index([organizationId, latestActivityAt])
  @@index([jobNumber])
  @@index([status, latestActivityAt])
}

model JobPart {
  id                     String                @id @default(cuid())
  jobId                  String
  itemId                 String
  quantity               Int
  unitCost               Float                 @default(0)
  notes                  String?
  createdAt              DateTime              @default(now())
  inventoryTransactionId String?
  performedByUserId      String?
  costSnapshot           Float?
  itemNameSnapshot       String?
  jobDescriptionSnapshot String?
  returnedQuantity       Int                   @default(0)
  lastActivityAt         DateTime              @default(now())
  inventoryTransaction   InventoryTransaction? @relation(fields: [inventoryTransactionId], references: [id])
  item                   Item                  @relation(fields: [itemId], references: [id])
  job                    Job                   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  performedByUser        AppUser?              @relation("JobPartPerformedBy", fields: [performedByUserId], references: [id])

  @@index([jobId])
  @@index([itemId])
  @@index([inventoryTransactionId])
  @@index([performedByUserId])
}

model Tool {
  id                String            @id @default(cuid())
  name              String
  manufacturer      String?
  partNumber        String?
  modelNumber       String?
  supplier          String?
  cost              Float             @default(0)
  notes             String?
  photoUrl          String?
  type              String            @default("SHOP")
  ownerId           String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  organizationId    String
  assetTag          String?
  serialNumber      String?
  category          String?
  replacementValue  Float?
  condition         String            @default("Good")
  currentStatus     String            @default("Available")
  assignedUserId    String?
  defaultLocation   String?
  lastTransactionAt DateTime?
  archived          Boolean           @default(false)
  assignedUser      AppUser?          @relation("AssignedCompanyTools", fields: [assignedUserId], references: [id])
  organization      Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner             AppUser?          @relation("PersonalTools", fields: [ownerId], references: [id])
  checkouts         ToolCheckout[]
  transactions      ToolTransaction[]

  @@unique([organizationId, assetTag])
  @@index([name])
  @@index([supplier])
  @@index([ownerId])
  @@index([organizationId])
  @@index([assignedUserId])
  @@index([organizationId, type])
  @@index([organizationId, currentStatus])
}

model ToolTransaction {
  id                 String       @id @default(cuid())
  organizationId     String
  toolId             String
  holderUserId       String?
  requestedByUserId  String?
  approvedByUserId   String?
  acceptedByUserId   String?
  status             String       @default("Requested")
  transactionType    String       @default("request")
  requestedAt        DateTime     @default(now())
  checkedOutAt       DateTime?
  dueBackAt          DateTime?
  returnRequestedAt  DateTime?
  returnedAt         DateTime?
  acceptedAt         DateTime?
  notes              String?
  issueReported      String?
  clientRequestId    String?      @unique
  submittedOfflineAt DateTime?
  syncStatus         String       @default("synced")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @default(now()) @updatedAt
  acceptedByUser     AppUser?     @relation("AcceptedToolTransactions", fields: [acceptedByUserId], references: [id])
  approvedByUser     AppUser?     @relation("ApprovedToolTransactions", fields: [approvedByUserId], references: [id])
  holderUser         AppUser?     @relation("HeldToolTransactions", fields: [holderUserId], references: [id])
  organization       Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedByUser    AppUser?     @relation("RequestedToolTransactions", fields: [requestedByUserId], references: [id])
  tool               Tool         @relation(fields: [toolId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([toolId])
  @@index([holderUserId])
  @@index([requestedByUserId])
  @@index([approvedByUserId])
  @@index([acceptedByUserId])
  @@index([organizationId, status])
  @@index([organizationId, requestedAt])
}

model ToolCheckout {
  id           String    @id @default(cuid())
  toolId       String
  userId       String
  checkedOutAt DateTime  @default(now())
  returnedAt   DateTime?
  notes        String?
  tool         Tool      @relation(fields: [toolId], references: [id], onDelete: Cascade)
  user         AppUser   @relation(fields: [userId], references: [id])

  @@index([toolId])
  @@index([userId])
}

model ReportView {
  id             String       @id @default(cuid())
  name           String
  type           String
  filters        String       @default("{}")
  sortBy         String       @default("name")
  archived       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model ShareLog {
  id             String       @id @default(cuid())
  type           String
  reportType     String?
  emailClient    String?
  filters        String       @default("{}")
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model ItemVariant {
  id             String       @id @default(cuid())
  itemId         String
  name           String
  sku            String?
  quantityOnHand Int          @default(0)
  attributes     String       @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  item           Item         @relation(fields: [itemId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([itemId])
}

model Location {
  id                            String                 @id @default(cuid())
  name                          String
  description                   String?
  archived                      Boolean                @default(false)
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt
  organizationId                String
  outboundInventoryTransactions InventoryTransaction[] @relation("InventoryTransactionsFromLocation")
  inboundInventoryTransactions  InventoryTransaction[] @relation("InventoryTransactionsToLocation")
  defaultItems                  Item[]                 @relation("DefaultItemLocation")
  organization                  Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stock                         LocationStock[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model LocationStock {
  id             String   @id @default(cuid())
  locationId     String
  itemId         String
  quantityOnHand Int      @default(0)
  updatedAt      DateTime @updatedAt
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  location       Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@unique([locationId, itemId])
  @@index([locationId])
  @@index([itemId])
}

model LocationTransfer {
  id             String       @id @default(cuid())
  fromLocationId String
  toLocationId   String
  itemId         String
  quantity       Int
  notes          String?
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([organizationId])
}

model ScheduledReport {
  id             String       @id @default(cuid())
  name           String
  reportType     String
  frequency      String
  filters        String       @default("{}")
  lastRun        DateTime?
  nextRun        DateTime
  archived       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Settings {
  id                             String       @id @default(cuid())
  premiumEnabled                 Boolean      @default(false)
  simpleMode                     Boolean      @default(true)
  enableMultiLocation            Boolean      @default(false)
  enableVariants                 Boolean      @default(false)
  enableImportWizard             Boolean      @default(false)
  enableLotExpiry                Boolean      @default(false)
  enableBackupZip                Boolean      @default(false)
  enableReportScheduler          Boolean      @default(false)
  enableAITagging                Boolean      @default(false)
  preferredEmailClient           String       @default("default")
  composeSubjectTemplate         String       @default("Inventory Report - {date}")
  defaultLowStockAmber           Int          @default(5)
  defaultLowStockRed             Int          @default(2)
  updatedAt                      DateTime     @updatedAt
  organizationId                 String       @unique
  enableToolsModule              Boolean      @default(true)
  requireToolReturnAcceptance    Boolean      @default(true)
  allowOfflineMode               Boolean      @default(true)
  allowOfflineQueue              Boolean      @default(true)
  allowOfflineCompanyToolFlows   Boolean      @default(true)
  offlineAutoSync                Boolean      @default(true)
  offlineCacheDays               Int          @default(30)
  defaultFinancialVisibilityMode String       @default("total_only")
  defaultCanViewBasePrice        Boolean      @default(false)
  defaultCanViewMarginPrice      Boolean      @default(false)
  defaultCanViewTotalPrice       Boolean      @default(true)
  organization                   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}
